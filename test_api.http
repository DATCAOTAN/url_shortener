@baseUrl = http://localhost:8080

### Test users
@userUsername = testuser
@userEmail = test@example.com
@userPassword = password123

@adminUsername = adminuser
@adminEmail = admin@system.com
@adminPassword = password123

### Tokens (paste from login responses)
@userAccessToken = <paste_user_access_token_here>
@userRefreshToken = <paste_user_refresh_token_here>
@adminAccessToken = <paste_admin_access_token_here>
@adminRefreshToken = <paste_admin_refresh_token_here>

### IDs and short code (paste from responses)
@userId = 1
@adminId = 12
@linkId = 1
@shortCode = rust
@expiredShortCode = expired1
@futureShortCode = futurettl

@fromDate = 2026-03-01
@toDate = 2026-03-31

##################################################
### PUBLIC
##################################################

### Root
GET {{baseUrl}}/

### Liveness
GET {{baseUrl}}/health/live

### Readiness
GET {{baseUrl}}/health/ready

### OpenAPI JSON
GET {{baseUrl}}/api-docs/openapi.json

### Docs hint
GET {{baseUrl}}/docs

### Redirect by short code
GET {{baseUrl}}/{{shortCode}}

### Redirect expired short code (expect 410 Gone)
GET {{baseUrl}}/{{expiredShortCode}}

### Redirect future TTL short code (expect 307/302)
GET {{baseUrl}}/{{futureShortCode}}


##################################################
### AUTH
##################################################

### Register user
POST {{baseUrl}}/register
Content-Type: application/json

{
  "username": "{{userUsername}}",
  "email": "{{userEmail}}",
  "password": "{{userPassword}}"
}

### Register admin account (then promote role in DB if needed)
POST {{baseUrl}}/register
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

### Login user (copy access_token, refresh_token)
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "{{userPassword}}"
}

### Login admin (copy access_token, refresh_token)
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

### Refresh user access token
POST {{baseUrl}}/refresh
Content-Type: application/json

{
  "refresh_token": "{{userRefreshToken}}"
}

### Logout user
POST {{baseUrl}}/logout
Content-Type: application/json

{
  "refresh_token": "{{userRefreshToken}}"
}


##################################################
### USER APIs (Bearer user/admin)
##################################################

### Get my profile
GET {{baseUrl}}/users/me
Authorization: Bearer {{userAccessToken}}

### Get user by id (owner-only on user route)
GET {{baseUrl}}/users/{{userId}}
Authorization: Bearer {{userAccessToken}}

### Create short link with TTL (expires_in_seconds)
POST {{baseUrl}}/api/links/create
Content-Type: application/json
Authorization: Bearer {{userAccessToken}}

{
  "original_url": "https://google.com",
  "title": "Google",
  "expires_in_seconds": 3600
}

### Create short link without TTL (vô thời hạn)
POST {{baseUrl}}/api/links/create
Content-Type: application/json
Authorization: Bearer {{userAccessToken}}

{
  "original_url": "https://example.com/no-expire",
  "title": "No Expire Link"
}

### List my links
GET {{baseUrl}}/links/my-links
Authorization: Bearer {{userAccessToken}}

### Daily analytics (all my links)
GET {{baseUrl}}/links/analytics?from={{fromDate}}&to={{toDate}}
Authorization: Bearer {{userAccessToken}}

### Soft delete my link
DELETE {{baseUrl}}/links/5
Authorization: Bearer {{userAccessToken}}


##################################################
### ADMIN APIs (Bearer admin only)
##################################################

### List all users
GET {{baseUrl}}/admin/users
Authorization: Bearer {{adminAccessToken}}

### Get one user by id
GET {{baseUrl}}/admin/users/{{userId}}
Authorization: Bearer {{adminAccessToken}}

### Soft delete user
DELETE {{baseUrl}}/admin/users/{{userId}}
Authorization: Bearer {{adminAccessToken}}

### Hard delete user
DELETE {{baseUrl}}/admin/users/{{userId}}/hard
Authorization: Bearer {{adminAccessToken}}

### List all links
GET {{baseUrl}}/admin/links
Authorization: Bearer {{adminAccessToken}}

### Disable link by id
DELETE {{baseUrl}}/admin/links/{{linkId}}
Authorization: Bearer {{adminAccessToken}}
