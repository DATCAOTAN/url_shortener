@shortCode = rust

@fromDate = 2026-03-01
@toDate = 2026-03-31

##################################################
### PUBLIC
##################################################

### Root
GET {{baseUrl}}/

### Liveness
GET {{baseUrl}}/health/live

### Readiness
GET {{baseUrl}}/health/ready

### OpenAPI JSON
GET {{baseUrl}}/api-docs/openapi.json

### Docs hint
GET {{baseUrl}}/docs

### Redirect by short code
GET {{baseUrl}}/{{shortCode}}


##################################################
### AUTH
##################################################

### Register user
POST {{baseUrl}}/register
Content-Type: application/json

{
  "username": "{{userUsername}}",
  "email": "{{userEmail}}",
  "password": "{{userPassword}}"
}

### Register admin account (then promote role in DB if needed)
POST {{baseUrl}}/register
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

### Login user (copy access_token, refresh_token)
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "{{userPassword}}"
}

### Login admin (copy access_token, refresh_token)
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

### Refresh user access token
POST {{baseUrl}}/refresh
Content-Type: application/json

{
  "refresh_token": "{{userRefreshToken}}"
}

### Logout user
POST {{baseUrl}}/logout
Content-Type: application/json

{
  "refresh_token": "{{userRefreshToken}}"
}


##################################################
### USER APIs (Bearer user/admin)
##################################################

### Get my profile
GET {{baseUrl}}/users/me
Authorization: Bearer {{userAccessToken}}

### Get user by id (owner-only on user route)
GET {{baseUrl}}/users/{{userId}}
Authorization: Bearer {{userAccessToken}}

### Create short link
POST {{baseUrl}}/links
Content-Type: application/json
Authorization: Bearer {{userAccessToken}}

{
  "original_url": "https://google.com",
  "title": "Google"
}

### List my links
GET {{baseUrl}}/links/my-links
Authorization: Bearer {{userAccessToken}}

### Daily analytics (all my links)
GET {{baseUrl}}/links/analytics?from={{fromDate}}&to={{toDate}}
Authorization: Bearer {{userAccessToken}}

### Soft delete my link
DELETE {{baseUrl}}/links/5
Authorization: Bearer {{userAccessToken}}


##################################################
### ADMIN APIs (Bearer admin only)
##################################################

### List all users
GET {{baseUrl}}/admin/users
Authorization: Bearer {{adminAccessToken}}

### Get one user by id
GET {{baseUrl}}/admin/users/{{userId}}
Authorization: Bearer {{adminAccessToken}}

### Soft delete user
DELETE {{baseUrl}}/admin/users/{{userId}}
Authorization: Bearer {{adminAccessToken}}

### Hard delete user
DELETE {{baseUrl}}/admin/users/{{userId}}/hard
Authorization: Bearer {{adminAccessToken}}

### List all links
GET {{baseUrl}}/admin/links
Authorization: Bearer {{adminAccessToken}}

### Disable link by id
DELETE {{baseUrl}}/admin/links/{{linkId}}
Authorization: Bearer {{adminAccessToken}}
